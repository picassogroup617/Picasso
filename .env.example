# =========================================================================
# Picasso - Environment Variables (Example / Template)
# -------------------------------------------------------------------------
# DO NOT put real secrets in this file. It is committed to git.
# Copy this file to `.env.local` (which is gitignored) and fill in values.
# =========================================================================

# --- Site ---
# In production set this to: https://picassogroup.in
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Picasso"
NEXT_PUBLIC_BRAND_TAGLINE="Crafting Excellence"

# --- Database (Neon Postgres) ---
# Format: postgresql://user:password@host/db?sslmode=verify-full
# Use the POOLED connection string for DATABASE_URL.
# Use the DIRECT (unpooled) connection string for DIRECT_URL (Prisma migrations).
DATABASE_URL=""
DIRECT_URL=""

# --- Auth.js (NextAuth v5) ---
# Generate with: npx auth secret
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# --- Initial Admin Seed (used once by `npm run db:seed`) ---
SEED_ADMIN_EMAIL="admin@picassogroup.in"
SEED_ADMIN_PASSWORD="ChangeMe!123"
SEED_ADMIN_NAME="Picasso Admin"

# --- Cloudinary (Image Storage) ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_FOLDER="picasso"

# --- SMTP (Email Notifications via Nodemailer) ---
# When any of SMTP_HOST / SMTP_FROM / QUOTE_NOTIFY_TO is missing the app
# falls back to a no-op notifier so quote submissions never fail.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Picasso <noreply@picassogroup.in>"
QUOTE_NOTIFY_TO="admin@picassogroup.in"

# --- Google Maps (Embed) ---
# Paste only the src="..." value from Google Maps -> Share -> Embed a map.
# Allowed origins: https://www.google.com/maps/embed, https://maps.google.com/maps
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=""
